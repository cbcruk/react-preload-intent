{
  "name": "react-preload-intent",
  "version": "0.1.0",
  "description": "React 19's react-dom/preload() with trigger taxonomy (render / intent / viewport / manual).",
  "keywords": [
    "hover",
    "image",
    "intent",
    "intersection-observer",
    "preload",
    "preloading",
    "react",
    "react-19",
    "viewport"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "demo": "vp dev --open",
    "build:demo": "vp build --base /react-preload-intent/ --outDir dist-demo",
    "test": "vp test",
    "check": "vp check",
    "format": "vp fmt",
    "typecheck": "tsc --noEmit",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^24.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.3.0"
}
